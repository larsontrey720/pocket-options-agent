# Pocket Options Trading Agent Configuration

# REQUIRED: Your Pocket Option SSID
# Get this from browser DevTools > Network > WS > Find 42["auth"...]
POCKET_OPTION_SSID=42["auth",{"session":"YOUR_SESSION_HERE","isDemo":1,"uid":YOUR_UID_HERE,"platform":1}]

# Account Mode (true = demo, false = real)
POCKET_OPTION_DEMO=true

# Trading Settings
POCKET_OPTION_AMOUNT=1          # Base trade amount in USD
POCKET_OPTION_DURATION=60       # Trade duration in seconds (min 5)
POCKET_OPTION_INTERVAL=120      # Time between analyses in seconds

# Risk Management
POCKET_OPTION_MAX_TRADES=10     # Max trades per session
POCKET_OPTION_MIN_CONFIDENCE=0.6  # Min AI confidence to trade (0.0-1.0)

# Assets (comma-separated)
POCKET_OPTION_ASSETS=EURUSD_otc,GBPUSD_otc,USDJPY_otc
